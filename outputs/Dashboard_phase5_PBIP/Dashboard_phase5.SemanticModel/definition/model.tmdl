model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["MCP-PBIModeling","DevMode"]

ref table categories
ref table customers
ref table employees
ref table orders
ref table order_items
ref table payments
ref table products
ref table promotions
ref table returns
ref table shipments
ref table stores
ref table suppliers
ref table Date
ref table _Measures

ref cultureInfo en-US

